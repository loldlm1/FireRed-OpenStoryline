diff --git a/tests/unit/mistral-stt-adapter.test.mjs b/tests/unit/mistral-stt-adapter.test.mjs
new file mode 100644
index 0000000..b762f8f
--- /dev/null
+++ b/tests/unit/mistral-stt-adapter.test.mjs
@@ -0,0 +1,47 @@
+import assert from "node:assert/strict";
+
+import { handleSttCore } from "../../open-sse/handlers/sttCore.js";
+import mistral from "../../open-sse/providers/registry/mistral.js";
+
+assert.ok(mistral.serviceKinds.includes("stt"));
+assert.equal(mistral.sttConfig.format, "mistral-stt");
+assert.ok(mistral.models.some((model) => model.id === "voxtral-mini-2602" && model.kind === "stt"));
+
+const incoming = new FormData();
+incoming.append("file", new File([new Uint8Array([1, 2, 3])], "sample.wav", { type: "audio/wav" }));
+incoming.append("model", "mistral/voxtral-mini-2602");
+incoming.append("language", "es");
+incoming.append("response_format", "verbose_json");
+
+let upstreamBody;
+let upstreamHeaders;
+globalThis.fetch = async (_url, options) => {
+  upstreamBody = options.body;
+  upstreamHeaders = options.headers;
+  return new Response(JSON.stringify({
+    text: "Hola mundo",
+    language: "es",
+    segments: [{ text: "Hola mundo", start: 0.2, end: 1.1 }],
+  }), { status: 200, headers: { "Content-Type": "application/json" } });
+};
+
+const result = await handleSttCore({
+  provider: "mistral",
+  model: "voxtral-mini-2602",
+  formData: incoming,
+  credentials: { apiKey: "test-key" },
+  sttConfig: mistral.sttConfig,
+});
+
+assert.equal(result.success, true);
+assert.equal(upstreamHeaders.Authorization, "Bearer test-key");
+assert.equal(upstreamBody.get("model"), "voxtral-mini-2602");
+assert.equal(upstreamBody.get("timestamp_granularities"), "segment");
+assert.equal(upstreamBody.get("language"), null);
+assert.equal(upstreamBody.get("response_format"), null);
+
+const payload = await result.response.json();
+assert.equal(payload.text, "Hola mundo");
+assert.deepEqual(payload.segments, [{ text: "Hola mundo", start: 0.2, end: 1.1 }]);
+
+console.log("mistral_stt_adapter_ok");
