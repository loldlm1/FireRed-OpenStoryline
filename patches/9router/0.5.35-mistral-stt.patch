diff --git a/open-sse/handlers/sttCore.js b/open-sse/handlers/sttCore.js
index acb7d13..42f80a1 100644
--- a/open-sse/handlers/sttCore.js
+++ b/open-sse/handlers/sttCore.js
@@ -98 +98,24 @@ async function transcribeNvidia(cfg, file, model, token) {
+// Mistral: request segment timestamps and normalize to the OpenAI verbose JSON shape.
+async function transcribeMistral(cfg, file, model, token, formData) {
+  const fd = new FormData();
+  fd.append("file", file, file.name || "audio.wav");
+  fd.append("model", model);
+  fd.append("timestamp_granularities", "segment");
+  const prompt = formData.get("prompt");
+  if (typeof prompt === "string" && prompt.trim()) fd.append("prompt", prompt.trim());
+
+  const res = await fetch(cfg.baseUrl, {
+    method: "POST",
+    headers: buildAuthHeaders(cfg, token),
+    body: fd,
+  });
+  if (!res.ok) return upstreamError(res);
+  const data = await res.json();
+  return jsonResponse({
+    text: data.text || "",
+    language: data.language || "",
+    segments: Array.isArray(data.segments) ? data.segments : [],
+  });
+}
+
 // Gemini: generateContent with inline_data audio + transcription prompt
