# Target server. Root is recommended for the first `kamal setup` so Kamal can install Docker.
KAMAL_HOST=203.0.113.10
KAMAL_SSH_USER=root
KAMAL_SSH_PORT=22

# Leave KAMAL_DOMAIN empty for http://KAMAL_HOST:KAMAL_HTTP_PORT.
# With a domain, point DNS to KAMAL_HOST and keep ports 80/443 for automatic HTTPS.
KAMAL_DOMAIN=
KAMAL_HTTP_PORT=80
KAMAL_HTTPS_PORT=443

# Persisted jobs and outputs on the server.
KAMAL_OUTPUTS_DIR=/var/lib/openstoryline/outputs

# Generate with: openssl rand -hex 32
OPENSTORYLINE_WEB_TOKEN=replace-with-a-long-random-token

# 9Router's OpenAI-compatible endpoint, reachable from the VPS, and endpoint key.
NINEROUTER_URL=https://your-9router.example.com
NINEROUTER_KEY=replace-with-your-9router-endpoint-key
OPENSTORYLINE_LLM_MODEL=cx/gpt-5.6-sol
OPENSTORYLINE_REASONING_EFFORT=medium
OPENSTORYLINE_LLM_TIMEOUT=180

# Codex OAuth image generation. No fallback model is allowed.
OPENSTORYLINE_IMAGE_MODELS=cx/gpt-5.5-image
OPENSTORYLINE_IMAGE_TIMEOUT=180
OPENSTORYLINE_IMAGE_MAX_BYTES=26214400
OPENSTORYLINE_IMAGE_SIZE=1024x1024

# Mistral remote-only STT. The provider key remains inside 9Router.
OPENSTORYLINE_STT_MODELS=mistral/voxtral-mini-2602
OPENSTORYLINE_STT_TIMEOUT=180
OPENSTORYLINE_MAX_UPLOAD_BYTES=8589934592

# Optional QA-only image already present on the VPS for the disposable
# container-to-host 9Router route probe. The script never pulls it.
NINEROUTER_PROBE_IMAGE=

# Mandatory for setup/deploy/redeploy. Keep this short synthetic speech fixture
# outside the repository; the release gate never persists its transcript.
NINEROUTER_QA_STT_AUDIO=/absolute/path/to/openstoryline-qa-speech.wav
NINEROUTER_QA_TIMEOUT=240

# Persistent protection for the single web key.
OPENSTORYLINE_AUTH_RPM=20
OPENSTORYLINE_AUTH_RPD=200
OPENSTORYLINE_AUTH_GLOBAL_RPM=600
OPENSTORYLINE_AUTH_GLOBAL_RPD=50000
OPENSTORYLINE_API_RPM=120
OPENSTORYLINE_API_RPD=10000
OPENSTORYLINE_JOBS_RPM=4
OPENSTORYLINE_JOBS_RPD=50

# Optional deterministic ComfyUI-FFMPEGA service on the same server.
OPENSTORYLINE_FFMPEGA_ENABLED=false
FFMPEGA_URL=http://host.docker.internal:8188
FFMPEGA_REMOTE_OUTPUT_ROOT=/var/lib/openstoryline/outputs
