# Target server. Root is recommended for the first `kamal setup` so Kamal can install Docker.
KAMAL_HOST=203.0.113.10
KAMAL_SSH_USER=root
KAMAL_SSH_PORT=22

# Leave KAMAL_DOMAIN empty for http://KAMAL_HOST:KAMAL_HTTP_PORT.
# With a domain, point DNS to KAMAL_HOST and keep ports 80/443 for automatic HTTPS.
KAMAL_DOMAIN=
KAMAL_HTTP_PORT=80
KAMAL_HTTPS_PORT=443

# Persisted jobs and outputs on the server.
KAMAL_OUTPUTS_DIR=/var/lib/openstoryline/outputs

# PostgreSQL runs as a private Kamal accessory on this same VPS.
KAMAL_POSTGRES_DATA_DIR=/var/lib/openstoryline/postgres
KAMAL_POSTGRES_BACKUP_DIR=/var/lib/openstoryline/backups
POSTGRES_PASSWORD=replace-with-a-long-random-database-admin-password
OPENSTORYLINE_DATABASE_PASSWORD=replace-with-a-different-long-random-app-password
DATABASE_URL=postgresql+psycopg://openstoryline:replace-with-the-app-password@openstoryline-mvp-db:5432/openstoryline
OPENSTORYLINE_DATABASE_CONNECT_TIMEOUT=10
OPENSTORYLINE_DATABASE_QUERY_TIMEOUT=5
OPENSTORYLINE_DATABASE_POOL_SIZE=5
OPENSTORYLINE_DATABASE_MAX_OVERFLOW=5

# Password login requires HTTPS in production.
# Generate the hash with the command below and keep the single quotes because
# Argon2id hashes contain `$` characters interpreted by the sourced shell file.
# ./bin/kamal-mvp auth hash-password
OPENSTORYLINE_WEB_PASSWORD_HASH='replace-with-an-argon2id-password-hash'
# Generate with: openssl rand -hex 32
OPENSTORYLINE_SECURITY_PEPPER=replace-with-a-long-random-security-pepper
OPENSTORYLINE_PUBLIC_ORIGIN=https://video.example.com
OPENSTORYLINE_ALLOW_INSECURE_HTTP=false
OPENSTORYLINE_SESSION_IDLE_HOURS=12
OPENSTORYLINE_SESSION_ABSOLUTE_DAYS=7
OPENSTORYLINE_SESSION_TOUCH_SECONDS=300

# 9Router's OpenAI-compatible endpoint, reachable from the VPS, and endpoint key.
NINEROUTER_URL=https://your-9router.example.com
NINEROUTER_KEY=replace-with-your-9router-endpoint-key
OPENSTORYLINE_LLM_MODEL=cx/gpt-5.6-sol
OPENSTORYLINE_REASONING_EFFORT=medium
OPENSTORYLINE_LLM_TIMEOUT=180

# Codex OAuth image generation. No fallback model is allowed.
OPENSTORYLINE_IMAGE_MODELS=cx/gpt-5.5-image
OPENSTORYLINE_IMAGE_TIMEOUT=180
OPENSTORYLINE_IMAGE_MAX_BYTES=26214400
OPENSTORYLINE_IMAGE_SIZE=1024x1024

# Direct Mistral Voxtral STT. Keep values only in this ignored deploy file.
# Ordered comma-separated keys enable bounded same-model failover.
MISTRAL_API_KEYS=replace-with-your-mistral-api-key
MISTRAL_STT_TIMEOUT=180
OPENSTORYLINE_MAX_UPLOAD_BYTES=8589934592

# Optional QA-only image already present on the VPS for the disposable
# container-to-host 9Router route probe. The script never pulls it.
NINEROUTER_PROBE_IMAGE=

NINEROUTER_QA_TIMEOUT=240

# Mandatory direct-Mistral gate for setup/deploy/redeploy. Keep the fixture
# short, synthetic, non-private, and outside the repository.
MISTRAL_QA_STT_AUDIO=/absolute/path/to/openstoryline-qa-speech.wav
MISTRAL_QA_TIMEOUT=240

# Only failed password submissions consume these persistent counters.
OPENSTORYLINE_LOGIN_RPM=10
OPENSTORYLINE_LOGIN_RPD=100
OPENSTORYLINE_LOGIN_GLOBAL_RPM=120
OPENSTORYLINE_LOGIN_GLOBAL_RPD=5000

# Optional deterministic ComfyUI-FFMPEGA service on the same server.
OPENSTORYLINE_FFMPEGA_ENABLED=false
FFMPEGA_URL=http://host.docker.internal:8188
FFMPEGA_REMOTE_OUTPUT_ROOT=/var/lib/openstoryline/outputs
