# Generate the hash with the command below and keep the single quotes because
# Argon2id hashes contain `$` characters interpreted by sourced env files.
# ./bin/kamal-mvp auth hash-password
OPENSTORYLINE_WEB_PASSWORD_HASH='replace-with-an-argon2id-password-hash'
# Generate with: openssl rand -hex 32
OPENSTORYLINE_SECURITY_PEPPER=replace-with-a-long-random-security-pepper
OPENSTORYLINE_PUBLIC_ORIGIN=http://127.0.0.1:8000
OPENSTORYLINE_ALLOW_INSECURE_HTTP=true
OPENSTORYLINE_SESSION_IDLE_HOURS=12
OPENSTORYLINE_SESSION_ABSOLUTE_DAYS=7
OPENSTORYLINE_SESSION_TOUCH_SECONDS=300
OPENSTORYLINE_LOGIN_RPM=10
OPENSTORYLINE_LOGIN_RPD=100
OPENSTORYLINE_LOGIN_GLOBAL_RPM=120
OPENSTORYLINE_LOGIN_GLOBAL_RPD=5000
OPENSTORYLINE_MAX_ACTIVE_JOBS=20
OPENSTORYLINE_AUDIT_MAX_DOCUMENT_BYTES=2097152
OPENSTORYLINE_RETENTION_ENABLED=false
OPENSTORYLINE_MEDIA_RETENTION_DAYS=7
OPENSTORYLINE_AUDIT_RETENTION_DAYS=30
OPENSTORYLINE_RETENTION_INTERVAL_SECONDS=86400
OPENSTORYLINE_RETENTION_BATCH_SIZE=100

# Local PostgreSQL. Production uses the private Kamal accessory hostname.
DATABASE_URL=postgresql+psycopg://openstoryline:replace-with-local-password@127.0.0.1:5432/openstoryline
OPENSTORYLINE_DATABASE_CONNECT_TIMEOUT=10
OPENSTORYLINE_DATABASE_QUERY_TIMEOUT=5
OPENSTORYLINE_DATABASE_POOL_SIZE=5
OPENSTORYLINE_DATABASE_MAX_OVERFLOW=5

# 9Router's OpenAI-compatible endpoint and its endpoint key.
NINEROUTER_URL=http://host.docker.internal:20128
NINEROUTER_KEY=replace-with-your-9router-endpoint-key
OPENSTORYLINE_LLM_MODEL=cx/gpt-5.6-sol
OPENSTORYLINE_REASONING_EFFORT=medium
OPENSTORYLINE_LLM_TIMEOUT=180

# Used by the full agent's SearchMedia generated-image source through Codex OAuth.
# This exact model must appear in 9Router /v1/models/image; no fallback exists.
OPENSTORYLINE_IMAGE_MODELS=cx/gpt-5.5-image
OPENSTORYLINE_IMAGE_TIMEOUT=180
OPENSTORYLINE_IMAGE_MAX_BYTES=26214400
OPENSTORYLINE_IMAGE_SIZE=1024x1024
# Remote MVP generated assets remain off until the image-provider release gate passes.
OPENSTORYLINE_GENERATED_ASSETS_ENABLED=false
OPENSTORYLINE_MAX_GENERATED_ASSETS_PER_CLIP=2

# Direct Mistral Voxtral STT. One or more ordered keys may be comma-separated.
MISTRAL_API_KEYS=replace-with-your-mistral-api-key
MISTRAL_STT_TIMEOUT=180

# Web/runtime limits.
OPENSTORYLINE_MAX_UPLOAD_BYTES=8589934592
OPENSTORYLINE_TRUST_PROXY_HEADERS=false
MVP_BIND_IP=127.0.0.1
MVP_PORT=8000
OPENSTORYLINE_OUTPUTS_DIR=./outputs

# Optional deterministic ComfyUI-FFMPEGA pass.
OPENSTORYLINE_FFMPEGA_ENABLED=false
FFMPEGA_URL=http://host.docker.internal:8188
# Required only when Docker and host ComfyUI see the shared volume under different paths.
FFMPEGA_LOCAL_OUTPUT_ROOT=/app/outputs
FFMPEGA_REMOTE_OUTPUT_ROOT=
