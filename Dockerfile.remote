FROM python:3.11-slim@sha256:db3ff2e1800a8581e2c48a27c3995339d47bdf046da21c7627accd3d51053a93

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app/src \
    XDG_CACHE_HOME=/tmp/.cache \
    OPENSTORYLINE_CONFIG=/app/config.toml \
    OPENSTORYLINE_CREATIVE_CATALOG_PATH=/app/creative_catalog/manifest.json

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ffmpeg curl fontconfig \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-remote.txt ./
RUN pip install --no-cache-dir -r requirements-remote.txt

COPY config.toml mvp_fastapi.py alembic.ini ./
COPY migrations/ ./migrations/
COPY src/open_storyline/__init__.py ./src/open_storyline/__init__.py
COPY src/open_storyline/mvp/ ./src/open_storyline/mvp/
COPY creative_catalog/ ./creative_catalog/
COPY scripts/generate_creative_catalog_manifest.py ./scripts/generate_creative_catalog_manifest.py
COPY web/mvp.html web/mvp-legacy.html ./web/
COPY web/static/mvp/ ./web/static/mvp/

RUN install -d -m 0755 /usr/local/share/fonts/openstoryline \
    && install -m 0644 creative_catalog/fonts/*.ttf /usr/local/share/fonts/openstoryline/ \
    && fc-cache -f \
    && python scripts/generate_creative_catalog_manifest.py --check \
    && python -m open_storyline.mvp.catalog \
    && groupadd --gid 65532 openstoryline \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /usr/sbin/nologin openstoryline \
    && install -d -m 0750 -o 65532 -g 65532 /app/outputs

EXPOSE 8000
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl -fsS http://127.0.0.1:8000/up || exit 1

USER 65532:65532

CMD ["uvicorn", "mvp_fastapi:app", "--host", "0.0.0.0", "--port", "8000", "--no-proxy-headers"]
