#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${KAMAL_ENV_FILE:-$ROOT_DIR/.env.kamal}"
MINIMUM_KAMAL_VERSION="2.12.0"
KAMAL_VERSION="${KAMAL_VERSION:-2.12.0}"

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_value() {
  local name="$1"
  local value="${!name:-}"
  [[ -n "$value" ]] || fail "$name is required in $ENV_FILE"
  [[ "$value" != replace-* ]] || fail "$name still contains an example value"
}

require_exact_value() {
  local name="$1"
  local expected="$2"
  local value="${!name:-}"
  [[ "$value" == "$expected" ]] \
    || fail "$name must be $expected for the approved no-fallback release"
}

run_ninerouter_release_gate() {
  local command_name="$1"
  local stt_audio="${NINEROUTER_QA_STT_AUDIO:-}"
  local timeout="${NINEROUTER_QA_TIMEOUT:-240}"
  local python_bin="${PYTHON_BIN:-python3}"

  [[ -n "$stt_audio" ]] \
    || fail "NINEROUTER_QA_STT_AUDIO is required before kamal $command_name"
  [[ -f "$stt_audio" ]] \
    || fail "NINEROUTER_QA_STT_AUDIO must point to a non-private speech fixture"
  [[ "$timeout" =~ ^[1-9][0-9]*$ ]] \
    || fail "NINEROUTER_QA_TIMEOUT must be a positive integer"
  command -v "$python_bin" >/dev/null 2>&1 \
    || fail "$python_bin is required to run the 9Router release gate"

  require_exact_value OPENSTORYLINE_LLM_MODEL "cx/gpt-5.6-sol"
  require_exact_value OPENSTORYLINE_IMAGE_MODELS "cx/gpt-5.5-image"
  require_exact_value OPENSTORYLINE_STT_MODELS "mistral/voxtral-mini-2602"

  printf 'Running mandatory redacted 9Router release gate before kamal %s...\n' "$command_name"
  "$python_bin" "$ROOT_DIR/scripts/qa_ninerouter.py" \
    --strict-models \
    --live-inference \
    --stt-audio "$stt_audio" \
    --timeout "$timeout" \
    || fail "9Router release gate failed; kamal $command_name was not started"
}

[[ -f "$ENV_FILE" ]] || fail "copy .env.kamal.example to .env.kamal and edit it first"

set -a
# shellcheck disable=SC1090
source "$ENV_FILE"
set +a

require_value KAMAL_HOST
require_value NINEROUTER_URL
require_value NINEROUTER_KEY
require_value OPENSTORYLINE_WEB_TOKEN

[[ ${#OPENSTORYLINE_WEB_TOKEN} -ge 16 ]] || fail "OPENSTORYLINE_WEB_TOKEN must contain at least 16 characters"
[[ "${KAMAL_SSH_PORT:-22}" =~ ^[0-9]+$ ]] || fail "KAMAL_SSH_PORT must be numeric"
[[ "${KAMAL_HTTP_PORT:-80}" =~ ^[0-9]+$ ]] || fail "KAMAL_HTTP_PORT must be numeric"
[[ "${KAMAL_HTTPS_PORT:-443}" =~ ^[0-9]+$ ]] || fail "KAMAL_HTTPS_PORT must be numeric"

if [[ -n "${KAMAL_DOMAIN:-}" ]]; then
  [[ "${KAMAL_HTTP_PORT:-80}" == 80 && "${KAMAL_HTTPS_PORT:-443}" == 443 ]] \
    || fail "automatic HTTPS requires KAMAL_HTTP_PORT=80 and KAMAL_HTTPS_PORT=443"
fi

command -v docker >/dev/null 2>&1 || fail "Docker is required on the deploy machine to build the image"
command -v gem >/dev/null 2>&1 || fail "RubyGems is required; install Ruby, then run: gem install kamal -v $KAMAL_VERSION"
command -v kamal >/dev/null 2>&1 || fail "Kamal is required; run: gem install kamal -v $KAMAL_VERSION"

oldest="$(printf '%s\n%s\n' "$MINIMUM_KAMAL_VERSION" "$KAMAL_VERSION" | sort -V | head -n 1)"
[[ "$oldest" == "$MINIMUM_KAMAL_VERSION" ]] \
  || fail "Kamal $KAMAL_VERSION is too old; run: gem install kamal -v $MINIMUM_KAMAL_VERSION"

gem list --installed --exact kamal --version "$KAMAL_VERSION" >/dev/null 2>&1 \
  || fail "Kamal $KAMAL_VERSION is not installed; run: gem install kamal -v $KAMAL_VERSION"

reported_version="$(kamal "_${KAMAL_VERSION}_" version 2>/dev/null | tail -n 1 | tr -d '[:space:]')"
[[ "$reported_version" == "$KAMAL_VERSION" ]] \
  || fail "Kamal $KAMAL_VERSION could not be selected (reported ${reported_version:-unknown})"

release_command=""
for arg in "$@"; do
  case "$arg" in
    setup|deploy|redeploy)
      release_command="$arg"
      break
      ;;
  esac
done
if [[ -n "$release_command" ]]; then
  run_ninerouter_release_gate "$release_command"
fi

mkdir -p "$ROOT_DIR/.kamal"
if [[ ! -f "$ROOT_DIR/.kamal/secrets" ]]; then
  cp "$ROOT_DIR/.kamal/secrets.example" "$ROOT_DIR/.kamal/secrets"
  chmod 600 "$ROOT_DIR/.kamal/secrets"
fi

cd "$ROOT_DIR"
exec kamal "_${KAMAL_VERSION}_" "$@"
