#!/usr/bin/env bash
set -Eeuo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENV_FILE="${KAMAL_ENV_FILE:-$ROOT_DIR/.env.kamal}"
MINIMUM_KAMAL_VERSION="2.12.0"
KAMAL_CLI_VERSION="${KAMAL_CLI_VERSION:-2.12.0}"

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

require_value() {
  local name="$1"
  local value="${!name:-}"
  [[ -n "$value" ]] || fail "$name is required in $ENV_FILE"
  [[ "$value" != replace-* ]] || fail "$name still contains an example value"
}

require_exact_value() {
  local name="$1"
  local expected="$2"
  local value="${!name:-}"
  [[ "$value" == "$expected" ]] \
    || fail "$name must be $expected for the approved no-fallback release"
}

require_boolean_flag() {
  local name="$1"
  local value="${!name:-false}"
  case "${value,,}" in
    true|false)
      ;;
    *)
      fail "$name must be true or false"
      ;;
  esac
}

validate_agentic_rollout_flags() {
  local mode="${OPENSTORYLINE_STRUCTURED_OUTPUT_MODE:-json_object}"
  local boundaries="${OPENSTORYLINE_STRUCTURED_OUTPUT_BOUNDARIES:-}"
  local capability_verified="${OPENSTORYLINE_STRUCTURED_OUTPUT_CAPABILITY_VERIFIED:-false}"
  local repair_mode="${OPENSTORYLINE_LLM_DEFECT_REPAIR_MODE:-off}"
  local semantic_qa="${OPENSTORYLINE_SEMANTIC_QA_ENABLED:-false}"
  local post_render_review="${OPENSTORYLINE_POST_RENDER_REVIEW_MODE:-off}"
  local ffmpega="${OPENSTORYLINE_FFMPEGA_ENABLED:-false}"
  local delivery="${OPENSTORYLINE_DELIVERY_POLICY:-qa_enforced}"
  local retry_ux="${OPENSTORYLINE_RETRY_UX_ENABLED:-false}"
  local baseline_fallbacks="${OPENSTORYLINE_BASELINE_FALLBACKS_ENABLED:-false}"
  local promotion_mode="${OPENSTORYLINE_RENDER_PROMOTION_MODE:-report}"
  local creative_qa="${OPENSTORYLINE_CREATIVE_QA_ENABLED:-true}"
  local creative_qa_strict="${OPENSTORYLINE_CREATIVE_QA_STRICT:-true}"
  local agentic_mode="${OPENSTORYLINE_AGENTIC_EDITING_MODE:-off}"
  local compact_boundaries="${boundaries//[[:space:]]/}"
  local stage=0
  local item
  local -a items=()
  declare -A enabled=()

  require_boolean_flag OPENSTORYLINE_STRUCTURED_OUTPUT_CAPABILITY_VERIFIED
  require_boolean_flag OPENSTORYLINE_SEMANTIC_QA_ENABLED
  require_boolean_flag OPENSTORYLINE_FFMPEGA_ENABLED
  require_boolean_flag OPENSTORYLINE_RETRY_UX_ENABLED
  require_boolean_flag OPENSTORYLINE_BASELINE_FALLBACKS_ENABLED
  require_boolean_flag OPENSTORYLINE_CREATIVE_QA_ENABLED
  require_boolean_flag OPENSTORYLINE_CREATIVE_QA_STRICT
  case "$repair_mode" in
    off|report|enforce) ;;
    *) fail "OPENSTORYLINE_LLM_DEFECT_REPAIR_MODE must be off, report, or enforce" ;;
  esac
  case "$promotion_mode" in
    off|report|enforce) ;;
    *) fail "OPENSTORYLINE_RENDER_PROMOTION_MODE must be off, report, or enforce" ;;
  esac
  case "$agentic_mode" in
    off|shadow|render) ;;
    *) fail "OPENSTORYLINE_AGENTIC_EDITING_MODE must be off, shadow, or render" ;;
  esac
  case "$post_render_review" in
    off|shadow|report|enforce) ;;
    *) fail "OPENSTORYLINE_POST_RENDER_REVIEW_MODE must be off, shadow, report, or enforce" ;;
  esac

  if [[ "$mode" == "json_object" ]]; then
    [[ -z "$compact_boundaries" ]] \
      || fail "strict boundaries require OPENSTORYLINE_STRUCTURED_OUTPUT_MODE=json_schema"
    [[ "$repair_mode" == "off" ]] \
      || fail "repair rollout requires all strict-schema boundaries first"
    [[ "${semantic_qa,,}" == "false" && "${ffmpega,,}" == "false" ]] \
      || fail "semantic QA and FFMPEGA require their strict-schema boundaries first"
    [[ "$post_render_review" == "off" ]] \
      || fail "post-render review requires its strict-schema boundary first"
    [[ "$delivery" == "qa_enforced" ]] \
      || fail "technical-pass delivery requires strict schema and enforced repair first"
    [[ "${retry_ux,,}" == "false" ]] \
      || fail "retry/details UI must be the final rollout flag"
    return
  fi
  [[ "$mode" == "json_schema" ]] \
    || fail "OPENSTORYLINE_STRUCTURED_OUTPUT_MODE must be json_object or json_schema"
  [[ "${capability_verified,,}" == "true" ]] \
    || fail "json_schema rollout requires a successful strict-schema probe"
  [[ -n "$compact_boundaries" ]] \
    || fail "json_schema rollout must start with shorts_selection.v1"

  IFS=',' read -r -a items <<< "$compact_boundaries"
  for item in "${items[@]}"; do
    case "$item" in
      shorts_selection.v1|visual_understanding.v1|edit_plan.v1|edit_plan_repair.v1|semantic_qa.v1|render_critic.v1|post_render_repair.v1|post_render_repair.v2|ffmpega_agentic_finishing.v1|ffmpega_deterministic_effects.v1)
        enabled["$item"]=1
        ;;
      *)
        fail "unknown structured-output rollout boundary: $item"
        ;;
    esac
  done

  [[ -n "${enabled[shorts_selection.v1]:-}" ]] \
    || fail "strict-schema rollout must enable shorts_selection.v1 first"
  stage=1
  if [[ -n "${enabled[visual_understanding.v1]:-}" ]]; then
    stage=2
  fi
  if [[ -n "${enabled[edit_plan.v1]:-}" || -n "${enabled[edit_plan_repair.v1]:-}" ]]; then
    [[ "$stage" -ge 2 ]] \
      || fail "edit-plan strict schemas require visual_understanding.v1 first"
    [[ -n "${enabled[edit_plan.v1]:-}" && -n "${enabled[edit_plan_repair.v1]:-}" ]] \
      || fail "edit_plan.v1 and edit_plan_repair.v1 must roll out together"
    stage=3
  fi
  if [[ -n "${enabled[semantic_qa.v1]:-}" ]]; then
    [[ "$stage" -ge 3 ]] \
      || fail "semantic_qa.v1 requires the edit-plan strict schemas first"
    stage=4
  fi
  if [[ -n "${enabled[render_critic.v1]:-}" ]]; then
    [[ "$stage" -ge 4 ]] \
      || fail "render_critic.v1 requires semantic_qa.v1 first"
    stage=5
  fi
  if [[ -n "${enabled[post_render_repair.v1]:-}" ]]; then
    [[ "$stage" -ge 5 ]] \
      || fail "post_render_repair.v1 requires render_critic.v1 first"
    stage=6
  fi
  if [[ -n "${enabled[ffmpega_agentic_finishing.v1]:-}" || -n "${enabled[ffmpega_deterministic_effects.v1]:-}" ]]; then
    [[ "$stage" -ge 5 ]] \
      || fail "FFMPEGA strict schemas require render_critic.v1 first"
    [[ -n "${enabled[ffmpega_agentic_finishing.v1]:-}" && -n "${enabled[ffmpega_deterministic_effects.v1]:-}" ]] \
      || fail "both FFMPEGA strict schemas must roll out together"
    stage=7
  fi
  if [[ -n "${enabled[post_render_repair.v2]:-}" ]]; then
    [[ "$stage" -ge 7 ]] \
      || fail "post_render_repair.v2 requires the FFMPEGA strict schemas first"
    [[ -n "${enabled[post_render_repair.v1]:-}" ]] \
      || fail "post_render_repair.v2 requires post_render_repair.v1 compatibility first"
    stage=8
  fi
  if [[ -z "${enabled[visual_understanding.v1]:-}" && "$stage" -gt 1 ]] \
    || [[ -z "${enabled[edit_plan.v1]:-}" && "$stage" -gt 2 ]] \
    || [[ -z "${enabled[semantic_qa.v1]:-}" && "$stage" -gt 3 ]] \
    || [[ -z "${enabled[render_critic.v1]:-}" && "$stage" -gt 4 ]] \
    || [[ -z "${enabled[post_render_repair.v1]:-}" && "$stage" -gt 5 ]] \
    || [[ -z "${enabled[ffmpega_agentic_finishing.v1]:-}" && "$stage" -gt 6 ]] \
    || [[ -z "${enabled[post_render_repair.v2]:-}" && "$stage" -gt 7 ]]; then
    fail "strict-schema boundaries must be a complete rollout prefix"
  fi

  if [[ "$repair_mode" != "off" ]]; then
    [[ "$stage" -ge 6 ]] \
      || fail "repair report/enforce requires every strict-schema boundary first"
    [[ "$agentic_mode" != "off" ]] \
      || fail "repair report/enforce requires agentic editing shadow or render mode"
  fi
  if [[ "$post_render_review" != "off" ]]; then
    [[ -n "${enabled[render_critic.v1]:-}" ]] \
      || fail "post-render review requires render_critic.v1"
    [[ "$agentic_mode" == "render" ]] \
      || fail "post-render review requires agentic render mode"
  fi
  if [[ "$post_render_review" == "enforce" ]]; then
    [[ -n "${enabled[post_render_repair.v2]:-}" ]] \
      || fail "post-render review enforce requires post_render_repair.v2"
    [[ "$repair_mode" == "enforce" ]] \
      || fail "post-render review enforce requires enforced LLM repair"
  fi
  if [[ "$repair_mode" == "enforce" ]]; then
    [[ "$agentic_mode" == "render" ]] \
      || fail "enforced repair requires OPENSTORYLINE_AGENTIC_EDITING_MODE=render"
  fi
  if [[ "$agentic_mode" == "render" ]]; then
    [[ "$repair_mode" == "enforce" ]] \
      || fail "production render requires OPENSTORYLINE_LLM_DEFECT_REPAIR_MODE=enforce"
    [[ "${baseline_fallbacks,,}" == "true" ]] \
      || fail "production render requires OPENSTORYLINE_BASELINE_FALLBACKS_ENABLED=true"
    [[ "${retry_ux,,}" == "true" ]] \
      || fail "production render requires OPENSTORYLINE_RETRY_UX_ENABLED=true"
  fi
  if [[ "${semantic_qa,,}" == "true" ]]; then
    [[ "$stage" -ge 4 ]] || fail "semantic QA requires semantic_qa.v1"
  fi
  if [[ "${ffmpega,,}" == "true" ]]; then
    [[ "$stage" -ge 7 ]] \
      || fail "FFMPEGA requires both strict FFMPEGA schemas"
  fi
  if [[ "$delivery" == "technical_pass_guaranteed" ]]; then
    [[ "$repair_mode" == "enforce" ]] \
      || fail "technical-pass delivery requires enforced LLM repair"
    [[ "$promotion_mode" == "enforce" ]] \
      || fail "technical-pass delivery requires enforced deterministic QA"
    [[ "${creative_qa,,}" == "true" && "${creative_qa_strict,,}" == "true" ]] \
      || fail "technical-pass delivery requires strict creative QA evidence"
  fi
  if [[ "${retry_ux,,}" == "true" ]]; then
    [[ "$delivery" == "technical_pass_guaranteed" ]] \
      || fail "retry/details UI must be enabled after technical-pass delivery"
  fi
}

resolve_python() {
  local candidate="${PYTHON_BIN:-$ROOT_DIR/.venv/bin/python}"
  if [[ -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return
  fi
  command -v python3 >/dev/null 2>&1 || fail "Python 3 is required for provider release gates"
  python3 -c 'import httpx' >/dev/null 2>&1 \
    || fail "httpx is required; install requirements-remote.txt or set PYTHON_BIN"
  command -v python3
}

run_ninerouter_release_gate() {
  local command_name="$1"
  local timeout="${NINEROUTER_QA_TIMEOUT:-240}"
  local python_bin
  local -a schema_probe_args=()
  python_bin="$(resolve_python)"

  [[ "$timeout" =~ ^[1-9][0-9]*$ ]] \
    || fail "NINEROUTER_QA_TIMEOUT must be a positive integer"
  require_exact_value OPENSTORYLINE_LLM_MODEL "cx/gpt-5.6-sol"
  require_exact_value OPENSTORYLINE_IMAGE_MODELS "cx/gpt-5.5-image"
  case "${OPENSTORYLINE_STRUCTURED_OUTPUT_MODE:-json_object}" in
    json_object)
      ;;
    json_schema)
      require_exact_value OPENSTORYLINE_STRUCTURED_OUTPUT_CAPABILITY_VERIFIED "true"
      [[ -n "${OPENSTORYLINE_STRUCTURED_OUTPUT_BOUNDARIES:-}" ]] \
        || fail "OPENSTORYLINE_STRUCTURED_OUTPUT_BOUNDARIES is required in json_schema mode"
      schema_probe_args+=(--strict-schema)
      ;;
    *)
      fail "OPENSTORYLINE_STRUCTURED_OUTPUT_MODE must be json_object or json_schema"
      ;;
  esac

  printf 'Running mandatory redacted 9Router release gate before kamal %s...\n' "$command_name"
  "$python_bin" "$ROOT_DIR/scripts/qa_ninerouter.py" \
    --strict-models \
    --live-inference \
    "${schema_probe_args[@]}" \
    --timeout "$timeout" \
    || fail "9Router release gate failed; kamal $command_name was not started"
}

run_mistral_release_gate() {
  local command_name="$1"
  local audio="${MISTRAL_QA_STT_AUDIO:-}"
  local timeout="${MISTRAL_QA_TIMEOUT:-240}"
  local python_bin
  python_bin="$(resolve_python)"

  [[ -n "$audio" ]] \
    || fail "MISTRAL_QA_STT_AUDIO is required before kamal $command_name"
  [[ -f "$audio" ]] \
    || fail "MISTRAL_QA_STT_AUDIO must point to a non-private speech fixture"
  [[ "$timeout" =~ ^[1-9][0-9]*$ ]] \
    || fail "MISTRAL_QA_TIMEOUT must be a positive integer"

  printf 'Running mandatory redacted direct-Mistral STT gate before kamal %s...\n' "$command_name"
  "$python_bin" "$ROOT_DIR/scripts/qa_mistral_stt.py" \
    --audio "$audio" \
    --timeout "$timeout" \
    --each-key \
    || fail "direct-Mistral STT gate failed; kamal $command_name was not started"
}

run_ffmpega_release_gate() {
  local command_name="$1"
  local enabled="${OPENSTORYLINE_FFMPEGA_ENABLED:-false}"
  case "${enabled,,}" in
    false|0|no|off)
      return
      ;;
    true|1|yes|on)
      ;;
    *)
      fail "OPENSTORYLINE_FFMPEGA_ENABLED must be true or false"
      ;;
  esac

  require_exact_value FFMPEGA_URL "http://openstoryline-mvp-ffmpega:8188"
  require_exact_value \
    FFMPEGA_REMOTE_OUTPUT_ROOT \
    "${KAMAL_OUTPUTS_DIR:-/var/lib/openstoryline/outputs}"
  printf 'Checking the pinned deterministic FFMPEGA service before kamal %s...\n' "$command_name"
  "$ROOT_DIR/scripts/mvp-ffmpega-service.sh" readiness
}

validate_pexels_release_config() {
  local command_name="$1"
  local enabled="${OPENSTORYLINE_PEXELS_ENABLED:-false}"
  local python_bin

  case "${enabled,,}" in
    false|0|no|off)
      return
      ;;
    true|1|yes|on)
      ;;
    *)
      fail "OPENSTORYLINE_PEXELS_ENABLED must be true or false"
      ;;
  esac

  require_value PEXELS_API_KEY
  require_value OPENSTORYLINE_PEXELS_LICENSE_REVIEWED_AT
  python_bin="$(resolve_python)"
  printf 'Validating the guarded Pexels release configuration before kamal %s...\n' "$command_name"
  PYTHONPATH="$ROOT_DIR/src" "$python_bin" - "$ROOT_DIR/config.toml" <<'PY'
from pathlib import Path
import sys

from open_storyline.mvp.settings import load_mvp_settings
from open_storyline.mvp.stock import PexelsClient, PexelsError

try:
    PexelsClient.from_config(load_mvp_settings(Path(sys.argv[1])).agentic_editing)
except PexelsError as exc:
    raise SystemExit(f"{exc.code}: guarded Pexels configuration is not release-ready") from None
PY
}

ensure_kamal() {
  command -v gem >/dev/null 2>&1 \
    || fail "RubyGems is required; install Ruby, then run: gem install kamal -v $KAMAL_CLI_VERSION"
  command -v kamal >/dev/null 2>&1 \
    || fail "Kamal is required; run: gem install kamal -v $KAMAL_CLI_VERSION"

  local oldest
  oldest="$(printf '%s\n%s\n' "$MINIMUM_KAMAL_VERSION" "$KAMAL_CLI_VERSION" | sort -V | head -n 1)"
  [[ "$oldest" == "$MINIMUM_KAMAL_VERSION" ]] \
    || fail "Kamal $KAMAL_CLI_VERSION is too old; run: gem install kamal -v $MINIMUM_KAMAL_VERSION"

  gem list --installed --exact kamal --version "$KAMAL_CLI_VERSION" >/dev/null 2>&1 \
    || fail "Kamal $KAMAL_CLI_VERSION is not installed; run: gem install kamal -v $KAMAL_CLI_VERSION"

  local reported_version
  reported_version="$(kamal "_${KAMAL_CLI_VERSION}_" version 2>/dev/null | tail -n 1 | tr -d '[:space:]')"
  [[ "$reported_version" == "$KAMAL_CLI_VERSION" ]] \
    || fail "Kamal $KAMAL_CLI_VERSION could not be selected (reported ${reported_version:-unknown})"
}

ensure_secrets_file() {
  mkdir -p "$ROOT_DIR/.kamal"
  if [[ ! -f "$ROOT_DIR/.kamal/secrets" ]]; then
    cp "$ROOT_DIR/.kamal/secrets.example" "$ROOT_DIR/.kamal/secrets"
    chmod 600 "$ROOT_DIR/.kamal/secrets"
  fi
}

run_remote_database_command() {
  local action="$1"
  local app_version="${OPENSTORYLINE_APP_VERSION:-}"
  local image_repository="localhost:5555/openstoryline-mvp"
  local image
  local local_env
  local remote_env
  local remote_command
  local target="${KAMAL_SSH_USER:-root}@${KAMAL_HOST}"
  local uploaded=false
  local -a ssh_args=(
    -o BatchMode=yes
    -o ConnectTimeout=15
    -p "${KAMAL_SSH_PORT:-22}"
  )
  local -a scp_args=(
    -q
    -o BatchMode=yes
    -o ConnectTimeout=15
    -P "${KAMAL_SSH_PORT:-22}"
  )

  if [[ -z "$app_version" ]]; then
    command -v git >/dev/null 2>&1 || fail "git is required to resolve the application image version"
    app_version="$(git -C "$ROOT_DIR" rev-parse HEAD)"
  fi
  [[ "$app_version" =~ ^[A-Za-z0-9._-]+$ ]] \
    || fail "OPENSTORYLINE_APP_VERSION contains unsupported characters"
  [[ "$DATABASE_URL" != *$'\n'* && "$DATABASE_URL" != *$'\r'* ]] \
    || fail "DATABASE_URL must be a single line"

  image="$image_repository:$app_version"
  remote_env="/tmp/openstoryline-database-${app_version}-${RANDOM}-$$.env"
  umask 077
  local_env="$(mktemp "${TMPDIR:-/tmp}/openstoryline-database.XXXXXX")"

  cleanup_remote_database_env() {
    rm -f "$local_env"
    if [[ "$uploaded" == true ]]; then
      ssh "${ssh_args[@]}" "$target" "rm -f '$remote_env'" >/dev/null 2>&1 || true
    fi
  }
  trap cleanup_remote_database_env EXIT INT TERM

  printf 'DATABASE_URL=%s\n' "$DATABASE_URL" > "$local_env"
  ssh "${ssh_args[@]}" "$target" "docker image inspect '$image' >/dev/null" \
    || fail "application image $image is not available on $KAMAL_HOST"
  scp "${scp_args[@]}" "$local_env" "$target:$remote_env"
  uploaded=true

  case "$action" in
    migrate)
      remote_command="alembic upgrade head"
      ;;
    current)
      remote_command="alembic current"
      ;;
    readiness)
      remote_command="python -c 'import asyncio; from open_storyline.mvp.database import Database; database = Database.from_env(); result = asyncio.run(database.readiness()); print(result.code); raise SystemExit(0 if result.ready else 1)'"
      ;;
    *)
      fail "unsupported database command: $action"
      ;;
  esac

  ssh "${ssh_args[@]}" "$target" \
    "set -eu; chmod 600 '$remote_env'; docker run --rm --network kamal --env-file '$remote_env' '$image' $remote_command"
  cleanup_remote_database_env
  trap - EXIT INT TERM
}

run_database_command() {
  local action="${1:-}"
  local mode="${OPENSTORYLINE_POSTGRES_ADMIN_MODE:-kamal}"
  local python_bin

  case "$action" in
    migrate|current|readiness|backup|restore-check)
      ;;
    *)
      fail "usage: bin/kamal-mvp db {migrate|current|readiness|backup|restore-check}"
      ;;
  esac

  if [[ "$mode" == "local" ]]; then
    case "$action" in
      migrate|current)
        require_value DATABASE_URL
        python_bin="$(resolve_python)"
        cd "$ROOT_DIR"
        if [[ "$action" == "migrate" ]]; then
          exec "$python_bin" -m alembic upgrade head
        fi
        exec "$python_bin" -m alembic current
        ;;
      readiness)
        require_value DATABASE_URL
        python_bin="$(resolve_python)"
        cd "$ROOT_DIR"
        exec "$python_bin" -c 'import asyncio; from open_storyline.mvp.database import Database; database = Database.from_env(); result = asyncio.run(database.readiness()); print(result.code); raise SystemExit(0 if result.ready else 1)'
        ;;
      backup)
        exec "$ROOT_DIR/scripts/mvp-postgres-backup.sh"
        ;;
      restore-check)
        exec "$ROOT_DIR/scripts/mvp-postgres-restore-check.sh"
        ;;
    esac
  fi

  [[ "$mode" == "kamal" ]] \
    || fail "OPENSTORYLINE_POSTGRES_ADMIN_MODE must be local or kamal"
  require_value KAMAL_HOST
  [[ "${KAMAL_SSH_PORT:-22}" =~ ^[0-9]+$ ]] || fail "KAMAL_SSH_PORT must be numeric"

  case "$action" in
    migrate|current|readiness)
      require_value DATABASE_URL
      run_remote_database_command "$action"
      ;;
    backup)
      exec "$ROOT_DIR/scripts/mvp-postgres-backup.sh"
      ;;
    restore-check)
      exec "$ROOT_DIR/scripts/mvp-postgres-restore-check.sh"
      ;;
  esac
}

if [[ "${1:-}" == "auth" && "${2:-}" == "hash-password" && $# -eq 2 ]]; then
  python_bin="$(resolve_python)"
  cd "$ROOT_DIR"
  exec env PYTHONPATH="$ROOT_DIR/src" "$python_bin" -m open_storyline.mvp.auth hash-password
fi

if [[ -f "$ENV_FILE" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$ENV_FILE"
  set +a
elif [[ "${OPENSTORYLINE_POSTGRES_ADMIN_MODE:-kamal}" != "local" ]]; then
  fail "copy .env.kamal.example to .env.kamal and edit it first"
fi

if [[ "${1:-}" == "rollout" && "${2:-}" == "validate" && $# -eq 2 ]]; then
  validate_agentic_rollout_flags
  printf 'Agentic rollout flags are ordered and internally consistent.\n'
  exit 0
fi

if [[ "${1:-}" == "db" ]]; then
  shift
  run_database_command "${1:-}"
  exit 0
fi

if [[ "${1:-}" == "ffmpega" ]]; then
  shift
  exec "$ROOT_DIR/scripts/mvp-ffmpega-service.sh" "$@"
fi

if [[ "${1:-}" == "audit" || "${1:-}" == "retention" || "${1:-}" == "workspace" ]]; then
  admin_command="$1"
  shift
  require_value KAMAL_HOST
  ensure_kamal
  ensure_secrets_file
  cd "$ROOT_DIR"
  exec kamal "_${KAMAL_CLI_VERSION}_" app exec --primary --reuse \
    env PYTHONPATH=/app/src python -m open_storyline.mvp.admin "$admin_command" "$@"
fi

require_value KAMAL_HOST
require_value DATABASE_URL
require_value POSTGRES_PASSWORD
require_value OPENSTORYLINE_DATABASE_PASSWORD
require_value NINEROUTER_URL
require_value NINEROUTER_KEY
require_value MISTRAL_API_KEYS
require_value OPENSTORYLINE_WEB_PASSWORD_HASH
require_value OPENSTORYLINE_SECURITY_PEPPER
require_value OPENSTORYLINE_PUBLIC_ORIGIN

[[ "$OPENSTORYLINE_WEB_PASSWORD_HASH" == \$argon2id\$* ]] \
  || fail "OPENSTORYLINE_WEB_PASSWORD_HASH must be an Argon2id hash"
[[ ${#OPENSTORYLINE_SECURITY_PEPPER} -ge 32 ]] \
  || fail "OPENSTORYLINE_SECURITY_PEPPER must contain at least 32 characters"
[[ "${KAMAL_SSH_PORT:-22}" =~ ^[0-9]+$ ]] || fail "KAMAL_SSH_PORT must be numeric"
[[ "${KAMAL_HTTP_PORT:-80}" =~ ^[0-9]+$ ]] || fail "KAMAL_HTTP_PORT must be numeric"
[[ "${KAMAL_HTTPS_PORT:-443}" =~ ^[0-9]+$ ]] || fail "KAMAL_HTTPS_PORT must be numeric"
case "${OPENSTORYLINE_DELIVERY_POLICY:-qa_enforced}" in
  qa_enforced|technical_pass_guaranteed)
    ;;
  *)
    fail "OPENSTORYLINE_DELIVERY_POLICY must be qa_enforced or technical_pass_guaranteed"
    ;;
esac
validate_agentic_rollout_flags

if [[ -n "${KAMAL_DOMAIN:-}" ]]; then
  [[ "${KAMAL_HTTP_PORT:-80}" == 80 && "${KAMAL_HTTPS_PORT:-443}" == 443 ]] \
    || fail "automatic HTTPS requires KAMAL_HTTP_PORT=80 and KAMAL_HTTPS_PORT=443"
  [[ "$OPENSTORYLINE_PUBLIC_ORIGIN" == "https://${KAMAL_DOMAIN}" ]] \
    || fail "OPENSTORYLINE_PUBLIC_ORIGIN must be https://$KAMAL_DOMAIN"
  [[ "${OPENSTORYLINE_ALLOW_INSECURE_HTTP:-false}" == "false" ]] \
    || fail "OPENSTORYLINE_ALLOW_INSECURE_HTTP must be false in domain mode"
else
  [[ "${OPENSTORYLINE_ALLOW_INSECURE_HTTP:-false}" == "true" ]] \
    || fail "direct-port mode requires explicit OPENSTORYLINE_ALLOW_INSECURE_HTTP=true"
fi

command -v docker >/dev/null 2>&1 || fail "Docker is required on the deploy machine to build the image"
ensure_kamal

if [[ "${1:-}" == "rollback" ]]; then
  rollback_version="${2:-}"
  [[ "$rollback_version" =~ ^[A-Za-z0-9._-]+$ ]] \
    || fail "rollback requires an explicit target version for schema compatibility validation"
  printf 'Checking the rollback image against the current PostgreSQL schema...\n'
  OPENSTORYLINE_APP_VERSION="$rollback_version" run_remote_database_command readiness
fi

release_command=""
for arg in "$@"; do
  case "$arg" in
    setup|deploy|redeploy)
      release_command="$arg"
      break
      ;;
  esac
done
if [[ -n "$release_command" ]]; then
  validate_pexels_release_config "$release_command"
  run_ninerouter_release_gate "$release_command"
  run_mistral_release_gate "$release_command"
  run_ffmpega_release_gate "$release_command"
fi

ensure_secrets_file

cd "$ROOT_DIR"
exec kamal "_${KAMAL_CLI_VERSION}_" "$@"
